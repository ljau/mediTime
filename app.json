{
  "expo": {
    "name": "MediTime",
    "slug": "meditime",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "meditime",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0F766E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.meditime.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F766E"
      },
      "package": "com.meditime.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "color": "#0F766E"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
