{
  "expo": {
    "name": "MediTime",
    "slug": "meditime",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "meditime",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#0F766E"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.meditime.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "notification": {
        "icon": "./assets/notification-icon.png",
        "color": "#0F766E"
      },
      "package": "com.meditime.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6f13e517-0aae-47a0-9a88-c69d822c5592",
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0F766E"
        }
      ],
      "expo-localization",
      "@react-native-community/datetimepicker",
      "./plugins/withAndroidNotificationLargeIcon.js"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6f13e517-0aae-47a0-9a88-c69d822c5592"
      }
    },
    "owner": "ljau"
  }
}
