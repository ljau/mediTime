{
  "cli": {
    "version": ">= 18.8.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "channel": "development",
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "node": "18.18.0",
      "env": {
        "EXPO_USE_BUN": "0",
        "NODE_ENV": "production"
      }
    },
    "ios-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "channel": "preview",
      "distribution": "internal",
      "environment": "preview",
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "node": "18.18.0",
      "env": {
        "EXPO_USE_BUN": "0",
        "NODE_ENV": "production"
      }
    },
    "production": {
      "channel": "production",
      "environment": "production",
      "autoIncrement": true,
      "node": "18.18.0",
      "ios": {
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_USE_BUN": "0",
        "NODE_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
